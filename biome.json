{
    "$schema": "/Users/ihorvasyliev/Library/pnpm/global/5/node_modules/@biomejs/biome/configuration_schema.json",
    "javascript": {
       "formatter": {
         "quoteStyle": "single",
         "jsxQuoteStyle": "double",
         "quoteProperties": "asNeeded",
         "trailingCommas": "none",
         "semicolons": "always",
         "arrowParentheses": "asNeeded",
         "bracketSpacing": true,
         "bracketSameLine": false,
            "expand": "always"
       }
     },
     "json": {
       "formatter": {
         "enabled": true,
         "trailingCommas": "none"
       }
     },
    "formatter": {
        "enabled": true,
        "formatWithErrors": false,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 100,
        "attributePosition": "multiline",
        "expand": "always"
    }
}
